{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "conan-release",
      "displayName": "Conan Release",
      "description": "Release configure preset backed by Conan-generated dependencies",
      "binaryDir": "${sourceDir}/build",
      "toolchainFile": "generators/conan_toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "conan-release",
      "configurePreset": "conan-release",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "conan-release",
      "configurePreset": "conan-release",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": true
      }
    }
  ]
}